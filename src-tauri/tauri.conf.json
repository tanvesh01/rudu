{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rudu",
  "version": "0.1.0",
  "identifier": "com.tanvesh.rudu",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rudu",
        "width": 800,
        "height": 600,
        "minWidth": 1400,
        "minHeight": 900,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tanvesh01/rudu/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyRkUxMjIzMTAxRjc5QjkKUldTNWVSOFFJeEwrSW83VXZXUjkrYlVEU1JHUWNhUEtYbWUwUlFGL0tFNWNBaTVCWUlTd1RoY3UK"
    }
  }
}
